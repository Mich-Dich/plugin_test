{
    "version": 4,
    "configurations": [
        {
            "name": "Debug (linux-x86_64)",
            "includePath": [
                "${workspaceFolder}/**",
                "${workspaceFolder}/vendor/glm/**"
            ],
            "defines": [
                "PLATFORM_LINUX",
                "DEBUG",
                "IMGUI_DEFINE_MATH_OPERATORS",
                "RENDER_API_VULKAN",
                "PLUGIN_NAME=DEFINED_IN_THE_CMAKE_BUILD_FILE_OF_THIS_PLUGIN"
            ],
            "compilerPath": "/usr/bin/gcc",
            "cStandard": "c11",
            "cppStandard": "c++23",
            "intelliSenseMode": "linux-gcc-x64"
        }
    ]
}